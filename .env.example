# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=
GOOGLE_MAPS_PLATFORM_KEY=

# SMTP Configuration for Contact Form
# Use 'smtp.gmail.com' for Host and '587' for Port if using Gmail.
SMTP_HOST=
SMTP_PORT=587
# Your full email address (e.g., madeccco5@gmail.com)
SMTP_USER=
# IMPORTANT: For Gmail, you MUST use a 16-character 'App Password'.
# Regular passwords will result in a 535 Authentication Error.
SMTP_PASS=
CONTACT_RECEIVER_EMAIL="madeccco5@gmail.com"

# Initial Admin Access Keys
CEO_ACCESS_KEY=CEO_MADECC_2026
PM_ACCESS_KEY=PM_MADECC_2026
CE_ACCESS_KEY=CE_MADECC_2026
FO_ACCESS_KEY=FO_MADECC_2026
ACC_ACCESS_KEY=ACC_MADECC_2026
SEC_ACCESS_KEY=SEC_MADECC_2026
