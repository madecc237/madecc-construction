# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=
GOOGLE_MAPS_PLATFORM_KEY=

# SMTP Configuration for Contact Form & MFA
# Host: 'smtp.gmail.com' for Google
SMTP_HOST=smtp.gmail.com
# Port: '587' (TLS) or '465' (SSL)
SMTP_PORT=587
# Your full email address
SMTP_USER=
# IMPORTANT: For Gmail, you MUST use a 16-character 'App Password'.
# Regular passwords will result in a 535 Authentication Error.
SMTP_PASS=
# The email address that receives the contact form inquiries
CONTACT_RECEIVER_EMAIL=madeccco5@gmail.com

# Initial Admin Access Keys
CEO_ACCESS_KEY=your_ceo_key_here
PM_ACCESS_KEY=your_pm_key_here
CE_ACCESS_KEY=your_ce_key_here
FO_ACCESS_KEY=your_fo_key_here
ACC_ACCESS_KEY=your_acc_key_here
SEC_ACCESS_KEY=your_sec_key_here
